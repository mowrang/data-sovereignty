# Google OAuth Configuration (for MCP Server)
# Get these from Google Cloud Console: https://console.cloud.google.com/
# Enable Google Docs API and Google Drive API
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
GOOGLE_REFRESH_TOKEN=your-refresh-token
# Run: npm run mcp:get-token to get the refresh token

# MCP Server Path (optional, defaults to ./mcp-google-docs/dist/server.js)
MCP_SERVER_PATH=./mcp-google-docs/dist/server.js

# LangGraph API URL (defaults to http://localhost:54367)
LANGGRAPH_API_URL=http://localhost:54367

# Anthropic API Key (for Claude - resume updates)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key
